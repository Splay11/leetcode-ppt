{
  "name": "motion-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node tools/prepare-pages-routes.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "assets": "vite --open /asset-library/index.html",
    "sync-assets": "powershell -ExecutionPolicy Bypass -File tools/sync-asset-library.ps1",
    "tuning-server": "node tools/anim-tuning-server.mjs",
    "video:preview": "vite --open /max-depth-video.html",
    "video:browser": "powershell -ExecutionPolicy Bypass -File tools/install-chrome-headless-shell.ps1",
    "video:studio": "remotion studio src/maxDepth/video-export/remotion/index.js",
    "video:render": "npm run video:browser && remotion render src/maxDepth/video-export/remotion/index.js MaxDepth104 out/maxDepth104.mp4"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.464",
    "@remotion/cli": "^4.0.464",
    "@remotion/player": "^4.0.464",
    "@tailwindcss/vite": "^4.3.0",
    "framer-motion": "^12.39.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.464",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
